{
	"name": "@nghyane/arcane-codemode",
	"version": "0.1.5",
	"description": "Code Mode: convert tool-calling into TypeScript code generation for LLM orchestration",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		}
	},
	"files": [
		"src",
		"README.md"
	],
	"scripts": {
		"check": "tsgo -p tsconfig.json",
		"test": "bun test"
	},
	"dependencies": {
		"@nghyane/arcane-agent": "^0.1.5",
		"@nghyane/arcane-utils": "^0.1.5",
		"@sinclair/typebox": "^0.34.48"
	},
	"devDependencies": {
		"@types/bun": "^1.3.9"
	},
	"keywords": [
		"codemode",
		"ai",
		"llm",
		"tool-calling",
		"code-generation"
	],
	"author": "Can Bölük",
	"license": "GPL-3.0-or-later",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nghyane/arcane.git",
		"directory": "packages/codemode"
	},
	"homepage": "https://github.com/nghyane/arcane",
	"bugs": {
		"url": "https://github.com/nghyane/arcane/issues"
	},
	"engines": {
		"bun": ">=1.3.7"
	}
}
